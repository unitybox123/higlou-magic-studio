# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# Marketplace lives in its own repo (MARKET-PLACE-OUTLET) — never ship here
/don-baraton/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Secrets / local dumps — never commit
**/api key*.txt
**/*api*key*.txt
/tmp/
.engram/
eBay-*.csv

# Google Cloud Service Account credential files (never commit)
**/service-account*.json
**/*-service-account.json
**/clever-reserve*.json
**/google-vision*.json
**/gcp-*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

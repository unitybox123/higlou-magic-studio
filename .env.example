# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_ECONOMY_MODEL=gpt-4o-mini
OPENAI_ADVANCED_MODEL=gpt-4o

# Monthly operating target
MONTHLY_PRODUCT_TARGET=500
MONTHLY_BUDGET_WARNING_USD=75
MONTHLY_BUDGET_LIMIT_USD=100

# OpenAI pricing estimates per million tokens (editable; not hard-coded in business logic)
OPENAI_INPUT_PRICE_PER_MILLION=1
OPENAI_CACHED_INPUT_PRICE_PER_MILLION=0.5
OPENAI_OUTPUT_PRICE_PER_MILLION=6
OPENAI_ECONOMY_INPUT_PRICE_PER_MILLION=0.15
OPENAI_ECONOMY_CACHED_INPUT_PRICE_PER_MILLION=0.075
OPENAI_ECONOMY_OUTPUT_PRICE_PER_MILLION=0.6

# Google Vision pricing
GOOGLE_VISION_FREE_UNITS_MONTHLY=1000
GOOGLE_VISION_PRICE_PER_1000_UNITS=1.50

# Infrastructure estimates
SUPABASE_MONTHLY_BASE_COST=25
VERCEL_MONTHLY_BASE_COST=20
DOMAIN_MISC_MONTHLY_COST=3

# Analysis limits
DEFAULT_IMAGES_PER_PRODUCT=8
MAX_IMAGES_PER_PRODUCT=12
GOOGLE_VISION_MAX_IMAGES_PER_PRODUCT=4
MAX_RETRIES_PER_ANALYSIS=2

# Google Cloud Vision
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_CLIENT_EMAIL=
GOOGLE_CLOUD_PRIVATE_KEY=
GOOGLE_VISION_ENABLED=true
GOOGLE_VISION_MODE=fallback
GOOGLE_VISION_MAX_IMAGES=4

# Image analysis
MAX_ANALYSIS_IMAGES=12
MAX_IMAGE_SIZE_MB=10
ENABLE_BARCODE_SCANNING=true

# Higlou Photo Studio — COST ARCHITECTURE (prefer money safety)
# Default: one main white-bg photo per click; no auto paid retries; no multi-beat batch.
# Docs: docs/creative-cost-architecture.md
#
# Cheapest path for Main photo (recommended):
#   CREATIVE_STUDIO_PROVIDER=remove_bg   # or local_studio ($0)
#   CREATIVE_ALLOW_OPENAI_STUDIO_FALLBACK=0   # do NOT silently fall through to OpenAI
#   CREATIVE_PHOTO_STUDIO_PHASE=2
#   CREATIVE_MAX_PAID_CALLS_PER_PACK=3
#   CREATIVE_BUDGET_HARD_STOP=1
#   CREATIVE_DISABLE_AUTO_PAID_RETRY=1
#   CREATIVE_MAX_EXTRA_REFERENCES=0
REMOVE_BG_API_KEY=
REMOVE_BG_COST_USD=0.05
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_EDIT_COST_USD=0.04
OPENAI_IMAGE_GEN_COST_USD=0.12
# Force a single provider: remove_bg | openai_image | local_studio
# Empty = remove_bg (if key) → local_studio → openai ONLY if fallback enabled
CREATIVE_STUDIO_PROVIDER=remove_bg
CREATIVE_ALLOW_OPENAI_STUDIO_FALLBACK=0
CREATIVE_ALLOW_LOCAL_STUDIO=true
CREATIVE_PHOTO_STUDIO_PHASE=2
CREATIVE_MAX_PAID_CALLS_PER_PACK=3
CREATIVE_BUDGET_HARD_STOP=1
CREATIVE_DISABLE_AUTO_PAID_RETRY=1
CREATIVE_MAX_EXTRA_REFERENCES=0
CREATIVE_QA_MAX_AUTO_RETRIES=1
# Composite / CONTROLLED_GEN are NOT in the default photo-studio path.
# Keep openai only if you explicitly unlock campaign invent (unlockPhase ≥ 50).
CREATIVE_COMPOSITE_PROVIDER=local
CREATIVE_CONTROLLED_GEN_FALLBACK_COMPOSITE=0
CREATIVE_DEFAULT_MODE=economy

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRODUCT_IMAGES_BUCKET=product-images
NEXT_PUBLIC_APP_URL=http://localhost:3000
